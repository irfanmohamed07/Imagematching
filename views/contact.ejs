<%- include('partials/header', { title: 'Support — Crescent College Image Matching' }) %>

    <!-- Contact Hero -->
    <section class="hero-section" style="min-height: auto; padding-bottom: 40px;">
        <div class="hero-badge">Support</div>
        <h1 class="hero-title">
            Need <span class="highlight">Help?</span>
        </h1>
        <p class="hero-description">
            Having issues with the system? Contact us and we'll help you out.
        </p>
    </section>

    <!-- Contact Section -->
    <section class="contact" style="padding-top: 20px;">
        <div class="contact-container">
            <div class="contact-info">
                <h2>Get in touch</h2>
                <p>
                    Whether you need help with the matching system, have questions about the database, or need technical
                    support — we're here for you.
                </p>
                <div class="contact-details">
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <strong>Email</strong>
                            <p class="contact-text">crescentnotes53@gmail.com</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <strong>Response Time</strong>
                            <p class="contact-text">Within 24 hours</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-building"></i>
                        </div>
                        <div>
                            <strong>Location</strong>
                            <p class="contact-text">Crescent College Campus</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contact-form-wrapper">
                <form action="/contact" method="POST" class="contact-form">
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" name="name" id="name" placeholder="Your name" required>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" name="email" id="email" placeholder="you@example.com" required>
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea name="message" id="message" placeholder="Describe your issue or question..."
                            required></textarea>
                    </div>

                    <button type="submit" class="btn-submit">
                        Send Message <i class="fas fa-arrow-right"></i>
                    </button>

                    <% if (locals.loginsucess) { %>
                        <div class="success-message">
                            <i class="fas fa-check-circle"></i>
                            <%= loginsucess %>
                        </div>
                        <% } %>
                </form>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="features-section">
        <div class="section-header">
            <span class="section-badge">FAQ</span>
            <h2 class="section-title">Common questions</h2>
        </div>
        <div class="features-grid" style="max-width: 800px;">
            <div class="feature-card">
                <h3 class="feature-title">What photos work best?</h3>
                <p class="feature-description">
                    Clear, front-facing photos work best. We support JPG, PNG, and WebP formats.
                </p>
            </div>
            <div class="feature-card">
                <h3 class="feature-title">How accurate is matching?</h3>
                <p class="feature-description">
                    Our AI achieves 99.8% accuracy with proper quality photos.
                </p>
            </div>
            <div class="feature-card">
                <h3 class="feature-title">What info do I get?</h3>
                <p class="feature-description">
                    Name, RRN, department, year, and section for matched students.
                </p>
            </div>
            <div class="feature-card">
                <h3 class="feature-title">Is student data secure?</h3>
                <p class="feature-description">
                    Yes. All data is processed securely within college systems.
                </p>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>