<%- include('partials/header', { title: 'About — Crescent College Image Matching' }) %>

    <!-- About Hero Section -->
    <section class="hero-section">
        <div class="hero-badge">About</div>
        <h1 class="hero-title">
            Student Identification Made <span class="highlight">Simple</span>
        </h1>
        <p class="hero-description">
            Built for Crescent College to streamline student identification.
            Our AI-powered system helps staff quickly verify students from any photo.
        </p>
        <div class="hero-cta">
            <a href="/#upload" class="btn-primary">
                Try It Now
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
            </a>
            <a href="/contact" class="btn-secondary">
                Contact Support
            </a>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="features-section">
        <div class="section-header">
            <span class="section-badge">System Stats</span>
            <h2 class="section-title">Reliable identification system</h2>
        </div>
        <div class="features-grid">
            <div class="feature-card" style="text-align: center;">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem;">99.8%</div>
                <h3 class="feature-title">Accuracy</h3>
                <p class="feature-description">Industry-leading match precision</p>
            </div>
            <div class="feature-card" style="text-align: center;">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem;">&lt;1s</div>
                <h3 class="feature-title">Response Time</h3>
                <p class="feature-description">Lightning-fast processing</p>
            </div>
            <div class="feature-card" style="text-align: center;">
                <div style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem;">5000+</div>
                <h3 class="feature-title">Students</h3>
                <p class="feature-description">In the database</p>
            </div>
        </div>
    </section>

    <!-- Purpose Section -->
    <section class="how-it-works-section">
        <div class="section-header">
            <span class="section-badge">Purpose</span>
            <h2 class="section-title">Built for Crescent College</h2>
        </div>
        <div class="steps-container">
            <div class="step-card">
                <div class="feature-icon" style="margin: 0 auto 1rem;">🎓</div>
                <h3 class="step-title">Student Verification</h3>
                <p class="step-description">
                    Quickly identify students for administrative purposes.
                </p>
            </div>
            <div class="step-card">
                <div class="feature-icon" style="margin: 0 auto 1rem;">🔐</div>
                <h3 class="step-title">Secure Access</h3>
                <p class="step-description">
                    All data stays within college systems.
                </p>
            </div>
            <div class="step-card">
                <div class="feature-icon" style="margin: 0 auto 1rem;">📊</div>
                <h3 class="step-title">Complete Records</h3>
                <p class="step-description">
                    Access name, RRN, department, year, and section.
                </p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="cta-container">
            <h2 class="cta-title">Ready to identify a student?</h2>
            <p class="cta-description">
                Upload a photo and get instant results.
            </p>
            <div class="cta-buttons">
                <a href="/#upload" class="btn-white">
                    Start Now <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>